{
    "name": "careerboost",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "check": "biome check . && tsc --noEmit",
        "fix": "biome check --write .",
        "test": "vitest run",
        "db:init": "tsx scripts/db-init.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "prepare": "husky",
        "auth:gen": "pnpm dlx @better-auth/cli@latest generate --config ./src/server/auth/auth.ts --output ./src/server/drizzle/schemas/auth-schema.ts --yes"
    },
    "dependencies": {
        "@better-auth-ui/core": "^1.6.20",
        "@better-auth-ui/react": "^1.6.20",
        "@better-auth/drizzle-adapter": "^1.6.18",
        "@elysiajs/eden": "^1.4.9",
        "@logtape/elysia": "^2.1.4",
        "@logtape/logtape": "^2.1.4",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@tailwindcss/postcss": "^4.3.1",
        "@tanstack/react-query": "^5.101.0",
        "better-auth": "^1.6.18",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.2",
        "eden-tanstack-react-query": "^0.1.10",
        "elysia": "^1.4.28",
        "next": "^16.0.0",
        "next-themes": "^0.4.6",
        "nuqs": "^2.8.9",
        "postcss": "^8.5.15",
        "postgres": "^3.4.9",
        "radix-ui": "^1.5.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.31.10",
        "husky": "^9.1.7",
        "tsx": "^4.22.4",
        "typescript": "^5.7.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.8"
    }
}
